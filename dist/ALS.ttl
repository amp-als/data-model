<https://w3id.org/synapse/amp-als/vocab/XF24%20Extracellular%20Flux%20Analyzer> dcterms:source "https://cehs.unl.edu/borc/xfe-24-extracellular-flux-analyzer-seahorse-bioscience/"^^xsd:anyURI ;
