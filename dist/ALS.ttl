<https://w3id.org/synapse/amp-als/vocab/genomic%20DNA> linkml:description "Total genomic DNA" .

<https://w3id.org/synapse/amp-als/vocab/genomicFeatures> rdfs:seeAlso "https://en.wikipedia.org/wiki/General_feature_format"^^xsd:anyURI ;
    linkml:description "Data of sequence feature (continuous extent of biological sequence) that is of genomic origin." ;
    linkml:meaning "http://purl.obolibrary.org/obo/GENO_0000481"^^xsd:anyURI .

<https://w3id.org/synapse/amp-als/vocab/genomicVariants> linkml:description """Genomic alterations, including single nucleotide polymorphisms, short indels and structural variants. Use more specific term if possible, esp. if data is only of one specific subset.
""" ;
    linkml:meaning "http://edamontology.org/operation_3227"^^xsd:anyURI .

<https://w3id.org/synapse/amp-als/vocab/genomics> linkml:description "Genomic sequencing data" .

<https://w3id.org/synapse/amp-als/vocab/genotyping> linkml:description "The determination of the DNA sequence of an individual." ;
    linkml:meaning "http://purl.obolibrary.org/obo/NCIT_C45447"^^xsd:anyURI .

