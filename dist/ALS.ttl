<https://w3id.org/synapse/amp-als/vocab/single%20cell%20ATAC-seq> linkml:description "A molecular genetic technique where DNA is isolated from single cell (sc) samples and amplified to create a genomic library. Then the library is subjected to ATAC-seq, which isolates and sequences regions rich in open chromatin." ;
    linkml:meaning "http://purl.obolibrary.org/obo/NCIT_C179458"^^xsd:anyURI .

<https://w3id.org/synapse/amp-als/vocab/single%20molecule> linkml:description "" .

<https://w3id.org/synapse/amp-als/vocab/single%20molecule%20drug%20screen%20assay> linkml:description "An experiment in which a single molecule was used in an assay" .

<https://w3id.org/synapse/amp-als/vocab/single%20nucleus> dcterms:source "https://github.com/HumanCellAtlas/metadata-schema/blob/master/json_schema/type/process/sequencing/library_preparation_process.json"^^xsd:anyURI ;
    linkml:description "Single nuclei" .

<https://w3id.org/synapse/amp-als/vocab/single-cell> linkml:description "Single cell analysis" .

<https://w3id.org/synapse/amp-als/vocab/single-cell%20RNA-seq> linkml:description "A procedure that can determine the nucleotide sequence for all of the RNA transcripts in an amplified nucleotide sample that was derived from a single cell." ;
    linkml:meaning "http://purl.obolibrary.org/obo/NCIT_C171152"^^xsd:anyURI .

<https://w3id.org/synapse/amp-als/vocab/single-end> linkml:description "Single-end sequencing reads" .

<https://w3id.org/synapse/amp-als/vocab/single-nucleus> linkml:description "Single nucleus analysis" .

<https://w3id.org/synapse/amp-als/vocab/single-nucleus%20RNA-seq> linkml:description "A method for quantifying the transcriptome of individual cells, in which transcripts isolated from single nuclei are subjected to high-throughput sequencing and mapping to a reference genome." ;
    linkml:meaning "http://purl.obolibrary.org/obo/FBcv_0009001"^^xsd:anyURI .

<https://w3id.org/synapse/amp-als/vocab/singleEnd> linkml:description "A library preparation that results in the creation of a library of 5' ends of DNA." .

<https://w3id.org/synapse/amp-als/vocab/single_cell> linkml:description "Single-cell analysis data" .

<https://w3id.org/synapse/amp-als/vocab/skin%20biopsy> linkml:description "Cells derived from skin biopsy" .

<https://w3id.org/synapse/amp-als/vocab/smokingHistory> a linkml:SlotDefinition ;
    dcterms:title "Smoking History" ;
    linkml:description "Smoking history status" ;
    linkml:range <https://w3id.org/synapse/amp-als/vocab/SmokingStatusEnum> .

<https://w3id.org/synapse/amp-als/vocab/snATAC-seq> linkml:description "Single-nucleus Assay for Transposase-Accessible Chromatin sequencing (snATAC-seq) profiles chromatin accessibility at single-cell resolution using isolated nuclei, particularly valuable for analyzing frozen tissues and complex sample types." ;
    linkml:meaning "http://purl.obolibrary.org/obo/OBI_0002762"^^xsd:anyURI .

<https://w3id.org/synapse/amp-als/vocab/snRNA-seq> linkml:description "Single-nucleus RNA sequencing (snRNA-seq) profiles gene expression in individual cell nuclei, enabling transcriptomic analysis of cell types in tissues where whole-cell dissociation is challenging or introduces bias." ;
    linkml:meaning "http://purl.obolibrary.org/obo/OBI_0003109"^^xsd:anyURI .

<https://w3id.org/synapse/amp-als/vocab/sodium> a linkml:SlotDefinition ;
    dcterms:title "Sodium (mEq/L)" ;
    linkml:description "Serum sodium level" ;
    linkml:range <https://w3id.org/synapse/amp-als/vocab/float> .

