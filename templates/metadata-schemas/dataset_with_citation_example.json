{
  "schemaName": "TargetALSClinicalData",
  "schemaType": "clinical",
  "version": "1.0",
  "description": "Clinical assessment data from the Target ALS Natural History Study, including demographics, diagnosis information, and standardized clinical assessments collected over multiple visits from ALS patients and control participants.",
  "conformsTo": [
    "https://schema.datacite.org/meta/kernel-4.4/",
