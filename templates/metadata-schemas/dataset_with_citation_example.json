  "citationRecommendation": "Smith, J., Doe, J. (2023). Target ALS Natural History Study - Clinical Assessment Data. Sage Bionetworks. https://doi.org/10.7303/syn12345678",

  "attributes": [
    {
      "name": "visit_number",
      "description": "Sequential visit number for the study",
      "dataType": "integer",
      "required": true,
      "examples": ["1", "2", "3", "4", "5"]
    },
    {
      "name": "clinical_group",
      "description": "Clinical group classification",
      "dataType": "enum",
      "required": true,
      "validValues": [
        {
          "value": "ALS",
          "description": "Amyotrophic Lateral Sclerosis patient"
        },
        {
          "value": "Non-Neurological Control",
          "description": "Healthy control participant without neurological conditions"
        }
      ],
      "examples": ["ALS", "Non-Neurological Control"]
    },
    {
      "name": "als_diagnosis_revised_el_escorial",
      "description": "ALS diagnosis classification based on revised El Escorial criteria",
      "dataType": "enum",
      "required": false,
      "validValues": [
        {
          "value": "Definite ALS",
          "description": "Meets criteria for definite ALS"
        },
        {
          "value": "Probable ALS",
          "description": "Meets criteria for probable ALS"
        },
        {
          "value": "Probable ALS - Lab Supported",
          "description": "Probable ALS with laboratory support"
        },
        {
          "value": "Possible ALS",
          "description": "Meets criteria for possible ALS"
        }
      ],
      "examples": ["Definite ALS", "Probable ALS"]
    },
    {
      "name": "age_in_years",
      "description": "Age of participant in years at time of assessment",
      "dataType": "integer",
      "required": true,
      "validationRules": "Must be between 18 and 120, or -9999 for missing data",
      "examples": ["45", "52", "63", "58", "71"]
    },
    {
      "name": "sex_reported",
      "description": "Self-reported biological sex",
      "dataType": "enum",
      "required": true,
      "validValues": [
        {
          "value": "Male",
          "description": "Male sex"
        },
        {
          "value": "Female",
          "description": "Female sex"
        }
      ],
      "examples": ["Male", "Female"]
    }
  ]
}
