  "resourceType": "Dataset",
  "subjects": [
    "Amyotrophic Lateral Sclerosis",
    "ALS",
    "motor neuron disease",
    "clinical assessment",
    "ALSFRS-R",
    "natural history study",
    "longitudinal study"
  ],
