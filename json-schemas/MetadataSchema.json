{
    "$defs": {
        "AccessRightsEnum": {
            "description": "Information about access restrictions",
            "enum": [
                "Open",
                "Restricted",
                "Embargoed",
                "Controlled"
            ],
            "title": "AccessRightsEnum",
            "type": "string"
        },
        "DataTypeEnum": {
            "description": "Data type for metadata attributes",
            "enum": [
                "string",
                "integer",
                "float",
                "date",
                "datetime",
                "boolean",
                "enum"
            ],
            "title": "DataTypeEnum",
            "type": "string"
        },
        "IdentifierTypeEnum": {
            "description": "Type of persistent identifier",
            "enum": [
                "DOI",
                "ARK",
                "Handle",
                "URL",
                "URN",
                "PURL"
            ],
            "title": "IdentifierTypeEnum",
            "type": "string"
        },
        "MetadataAttribute": {
            "additionalProperties": false,
            "description": "Definition of a single metadata attribute/column including its data type, valid values, and validation rules.",
            "properties": {
                "dataType": {
                    "$ref": "#/$defs/DataTypeEnum",
                    "description": "Data type of this attribute"
                },
                "description": {
                    "description": "Detailed description of what this attribute represents",
                    "type": "string"
                },
                "examples": {
                    "description": "Example values to help users understand this attribute",
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "name": {
                    "description": "Name of the metadata attribute/column",
                    "type": "string"
                },
                "required": {
                    "description": "Whether this attribute must be present in the data",
                    "type": "boolean"
                },
                "validValues": {
                    "description": "List of allowed values for enumerated attributes. Only applicable when dataType is \"enum\".",
                    "items": {
                        "$ref": "#/$defs/ValidValue"
                    },
                    "type": "array"
                },
                "validationRules": {
                    "description": "Optional validation constraints or rules for this attribute (e.g., \"Must be between 1900 and current year\")",
                    "type": "string"
                }
            },
            "required": [
                "name",
                "description",
                "dataType"
            ],
            "title": "MetadataAttribute",
            "type": "object"
        },
        "MetadataSchema": {
            "additionalProperties": false,
            "description": "Template for defining metadata schemas that document the structure, data types, and valid values for clinical and omics metadata files. Also supports dataset-level citation metadata per NIH CADR requirements.",
            "properties": {
                "accessRights": {
                    "$ref": "#/$defs/AccessRightsEnum",
                    "description": "Information about access restrictions"
                },
                "attributes": {
                    "description": "List of metadata attributes/columns defined in this schema",
                    "items": {
                        "$ref": "#/$defs/MetadataAttribute"
                    },
                    "type": "array"
                },
                "citationRecommendation": {
                    "description": "Recommended citation format for this dataset",
                    "type": "string"
                },
                "conformsTo": {
                    "description": "URIs of community metadata standards this schema conforms to (e.g., DataCite, Dublin Core, DCAT, Schema.org)",
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "contactEmail": {
                    "description": "Email address for dataset inquiries",
                    "type": "string"
                },
                "contactName": {
                    "description": "Name of person/organization to contact for questions",
                    "type": "string"
                },
                "contributors": {
                    "description": "Additional persons/organizations contributing to the dataset. Format: LastName, FirstName (Role). Separate multiple with semicolons.",
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "creators": {
                    "description": "Main researchers/authors responsible for creating the dataset. Format: LastName, FirstName (ORCID). Separate multiple with semicolons.",
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "dateCreated": {
                    "description": "Date the dataset was originally created (YYYY-MM-DD)",
                    "format": "date",
                    "type": "string"
                },
                "dateModified": {
                    "description": "Date the dataset was last modified (YYYY-MM-DD)",
                    "format": "date",
                    "type": "string"
                },
                "datePublished": {
                    "description": "Date the dataset was published (YYYY-MM-DD)",
                    "format": "date",
                    "type": "string"
                },
                "description": {
                    "description": "Overall description of what this schema covers",
                    "type": "string"
                },
                "fundingReferences": {
                    "description": "Funding support information. Format: Funder Name (Award Number)",
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "identifier": {
                    "description": "Persistent identifier for the dataset (DOI, ARK, Handle). Required for dataset citation and discovery.",
                    "type": "string"
                },
                "identifierType": {
                    "$ref": "#/$defs/IdentifierTypeEnum",
                    "description": "Type of identifier (DOI, ARK, Handle, URL)"
                },
                "landingPage": {
                    "description": "URL to dataset landing page or repository entry",
                    "type": "string"
                },
                "license": {
                    "description": "License or rights statement for dataset use",
                    "type": "string"
                },
                "licenseURL": {
                    "description": "URL to the full license text",
                    "type": "string"
                },
                "publicationYear": {
                    "description": "Year the dataset was made publicly available",
                    "type": "integer"
                },
                "publisher": {
                    "description": "Institution/entity responsible for publishing the dataset",
                    "type": "string"
                },
                "relatedDatasets": {
                    "description": "Identifiers of related datasets",
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "relatedPublications": {
                    "description": "Citations or DOIs of related publications",
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "resourceType": {
                    "$ref": "#/$defs/ResourceTypeEnum",
                    "description": "General type of the resource (Dataset, Collection, etc.)"
                },
                "schemaName": {
                    "description": "Name of this metadata schema",
                    "type": "string"
                },
                "schemaType": {
                    "$ref": "#/$defs/SchemaTypeEnum",
                    "description": "Type of metadata this schema describes"
                },
                "subjects": {
                    "description": "Keywords or subject terms describing the dataset. Use controlled vocabularies (MeSH, SNOMED) when possible.",
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "title": {
                    "description": "Primary title of the dataset",
                    "type": "string"
                },
                "version": {
                    "description": "Version of this schema (e.g., \"1.0\", \"2.1\")",
                    "type": "string"
                }
            },
            "required": [
                "schemaName",
                "schemaType",
                "version",
                "attributes"
            ],
            "title": "MetadataSchema",
            "type": "object"
        },
        "ResourceTypeEnum": {
            "description": "General type of the resource",
            "enum": [
                "Dataset",
                "Collection",
                "DataPaper",
                "Software"
            ],
            "title": "ResourceTypeEnum",
            "type": "string"
        },
        "SchemaTypeEnum": {
            "description": "Type of metadata schema",
            "enum": [
                "clinical",
                "omics",
                "study",
                "dataset"
            ],
            "title": "SchemaTypeEnum",
            "type": "string"
        },
        "ValidValue": {
            "additionalProperties": false,
            "description": "Allowed value for an enumerated attribute, including a description of what the value means.",
            "properties": {
                "description": {
                    "description": "What this value means or represents",
                    "type": "string"
                },
                "value": {
                    "description": "The actual allowed value",
                    "type": "string"
                }
            },
            "required": [
                "value",
                "description"
            ],
            "title": "ValidValue",
            "type": "object"
        }
    },
    "$id": "https://amp-als.org/schemas/MetadataSchema",
    "$schema": "https://json-schema.org/draft/2019-09/schema",
    "additionalProperties": true,
    "metamodel_version": "1.7.0",
    "title": "metadata-schema",
    "type": "object",
    "version": null
}
