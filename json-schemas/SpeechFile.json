      "title": "Test Code (FTTESTCD)",
      "type": "array"
    },
    "ftTstDtl": {
      "description": "Indicates whether the measurement is Aggregate (summary across all steps) or Step-level (individual step within the test) (SDTM FTTSTDTL)\n",
