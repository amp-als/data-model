      "title": "Reference ID (FTREFID)",
      "type": "array"
    },
    "ftStat": {
      "description": "Completion status of the test. Set to \"Not Done\" when the test was not completed; leave empty or null when completed (SDTM FTSTAT).\n",
      "title": "Completion Status (FTSTAT)",
