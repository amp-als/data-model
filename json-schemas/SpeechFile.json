      "description": "Reason the test was not completed. Only applicable when ftStat = \"Not Done\" (SDTM FTREASND).\n",
      "title": "Reason Not Done (FTREASND)",
      "type": "string"
    },
    "ftRefId": {
      "description": "Reference identifier; SessionID when measurement is Aggregate, STEPID when measurement is Step-level (SDTM FTREFID)\n",
      "items": {
        "type": "string"
